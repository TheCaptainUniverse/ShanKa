{
  "name": "shanka",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,app -c cyan,green \"bun run dev:server\" \"bun run dev:app\"",
    "dev:app": "tauri dev",
    "dev:web": "vite",
    "dev:server": "bun --watch server/src/index.ts",
    "check": "bun run check:rust && bun test && bun run build",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo check --manifest-path src-tauri/Cargo.toml && cargo test --manifest-path src-tauri/Cargo.toml",
    "release:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-smoke.ps1",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit && bun run typecheck:server",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.15",
    "tailwindcss": "3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
